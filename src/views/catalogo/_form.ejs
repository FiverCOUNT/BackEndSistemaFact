<div class="field">
  <label for="companyRuc">Empresa (RUC) *</label>
  <select id="companyRuc" name="companyRuc" required>
    <option value="">— Seleccionar —</option>
    <% companies.forEach(function(c) { %>
      <option value="<%= c.ruc %>" <%= form.companyRuc === c.ruc ? 'selected' : '' %>>
        <%= c.nombre %> (<%= c.ruc %>)
      </option>
    <% }); %>
  </select>
</div>

<div class="form-grid">
  <div class="field">
    <label for="kind">Tipo *</label>
    <select id="kind" name="kind" required>
      <% kinds.forEach(function(k) { %>
        <option value="<%= k %>" <%= form.kind === k ? 'selected' : '' %>><%= k === 'PRODUCT' ? 'Producto' : 'Servicio' %></option>
      <% }); %>
    </select>
  </div>
  <div class="field field-full">
    <label for="nombre">Nombre *</label>
    <input type="text" id="nombre" name="nombre" value="<%= form.nombre || '' %>" required />
  </div>
  <div class="field">
    <label for="codigo">Código interno</label>
    <input type="text" id="codigo" name="codigo" value="<%= form.codigo || '' %>" maxlength="64" />
  </div>
  <div class="field field-full">
    <label for="descripcion">Descripción</label>
    <input type="text" id="descripcion" name="descripcion" value="<%= form.descripcion || '' %>" maxlength="500" />
  </div>
  <div class="field">
    <label for="unidad">Unidad *</label>
    <select id="unidad" name="unidad" required>
      <% unidades.forEach(function(u) { %>
        <option value="<%= u %>" <%= form.unidad === u ? 'selected' : '' %>><%= u %></option>
      <% }); %>
    </select>
  </div>
  <div class="field">
    <label for="precioUnitario">Precio unitario</label>
    <input type="number" id="precioUnitario" name="precioUnitario" value="<%= form.precioUnitario || '0' %>" min="0" step="0.01" />
  </div>
  <div class="field">
    <label for="afectacionIgv">Afectación IGV</label>
    <input type="text" id="afectacionIgv" name="afectacionIgv" value="<%= form.afectacionIgv || '10' %>" maxlength="4" />
  </div>
  <div class="field">
    <label for="stockActual">Stock (referencia)</label>
    <input type="number" id="stockActual" name="stockActual" value="<%= form.stockActual || '' %>" min="0" step="0.0001" disabled />
    <span class="field-hint">El stock real se registra en Inventario por almacén (entradas/salidas).</span>
  </div>
  <div class="field">
    <label for="duracionMinutos">Duración (min)</label>
    <input type="number" id="duracionMinutos" name="duracionMinutos" value="<%= form.duracionMinutos || '' %>" min="1" step="1" />
    <span class="field-hint">Servicios.</span>
  </div>
</div>

<div class="form-grid" style="margin-top: 0.75rem;">
  <div class="field field-check">
    <label><input type="checkbox" name="activo" <%= form.activo !== false ? 'checked' : '' %> /> Activo</label>
  </div>
  <div class="field field-check">
    <label><input type="checkbox" name="manejaStock" <%= form.manejaStock ? 'checked' : '' %> /> Maneja stock</label>
  </div>
  <div class="field field-check">
    <label><input type="checkbox" name="manejaSerie" <%= form.manejaSerie ? 'checked' : '' %> /> Maneja serie</label>
  </div>
</div>
