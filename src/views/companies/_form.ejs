<fieldset class="fieldset">
  <legend>Datos principales</legend>
  <div class="form-grid">
    <div class="field">
      <label for="ruc">RUC *</label>
      <input type="text" id="ruc" name="ruc" value="<%= form.ruc %>" maxlength="11" required />
    </div>
    <div class="field">
      <label for="nombre">Razón social *</label>
      <input type="text" id="nombre" name="nombre" value="<%= form.nombre %>" required />
    </div>
    <div class="field">
      <label for="nombreComercial">Nombre comercial</label>
      <input type="text" id="nombreComercial" name="nombreComercial" value="<%= form.nombreComercial %>" />
    </div>
    <div class="field">
      <label for="tipoDoc">Tipo doc.</label>
      <input type="text" id="tipoDoc" name="tipoDoc" value="<%= form.tipoDoc %>" maxlength="2" />
    </div>
    <div class="field">
      <label for="numeroDoc">Número doc.</label>
      <input type="text" id="numeroDoc" name="numeroDoc" value="<%= form.numeroDoc %>" />
    </div>
    <div class="field">
      <label for="taxRegime">Régimen tributario</label>
      <input type="text" id="taxRegime" name="taxRegime" value="<%= form.taxRegime %>" placeholder="RER, GENERAL..." />
    </div>
  </div>
</fieldset>

<fieldset class="fieldset">
  <legend>Contacto</legend>
  <div class="form-grid">
    <div class="field">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= form.email %>" />
    </div>
    <div class="field">
      <label for="telefono">Teléfono</label>
      <input type="text" id="telefono" name="telefono" value="<%= form.telefono %>" />
    </div>
  </div>
</fieldset>

<fieldset class="fieldset">
  <legend>Configuración</legend>
  <div class="form-grid">
    <div class="field">
      <label for="entorno">Entorno</label>
      <select id="entorno" name="entorno">
        <option value="beta" <%= form.entorno === 'beta' ? 'selected' : '' %>>beta</option>
        <option value="prod" <%= form.entorno === 'prod' ? 'selected' : '' %>>prod</option>
      </select>
    </div>
    <div class="field">
      <label for="plan">Plan</label>
      <input type="text" id="plan" name="plan" value="<%= form.plan %>" placeholder="free, pro..." />
    </div>
    <div class="field field-check">
      <label><input type="checkbox" name="activo" <%= form.activo ? 'checked' : '' %> /> Activa</label>
    </div>
    <div class="field field-check">
      <label><input type="checkbox" name="isActive" <%= form.isActive ? 'checked' : '' %> /> isActive</label>
    </div>
  </div>
</fieldset>

<fieldset class="fieldset">
  <legend>Series y correlativos SUNAT</legend>
  <p class="field-hint field-full">Define la serie (4 caracteres, ej. F001), el número inicial y cuántos dígitos lleva el correlativo por tipo de comprobante. SUNAT exige serie de 4 caracteres en el nombre del ZIP enviado. El siguiente documento será el mayor correlativo emitido + 1, o el inicial si aún no hay comprobantes.</p>
  <div class="form-grid">
    <div class="field field-full"><strong>Factura (01)</strong></div>
    <div class="field">
      <label for="serie_01">Serie</label>
      <input type="text" id="serie_01" name="serie_01" value="<%= form.serie_01 %>" maxlength="4" minlength="4" pattern="[A-Za-z0-9]{4}" placeholder="F001" />
    </div>
    <div class="field">
      <label for="correlativo_inicio_01">Correlativo inicial</label>
      <input type="number" id="correlativo_inicio_01" name="correlativo_inicio_01" value="<%= form.correlativo_inicio_01 %>" min="1" step="1" />
    </div>
    <div class="field">
      <label for="correlativo_digitos_01">Dígitos correlativo</label>
      <input type="number" id="correlativo_digitos_01" name="correlativo_digitos_01" value="<%= form.correlativo_digitos_01 %>" min="1" max="20" step="1" placeholder="8" />
    </div>

    <div class="field field-full"><strong>Boleta (03)</strong></div>
    <div class="field">
      <label for="serie_03">Serie</label>
      <input type="text" id="serie_03" name="serie_03" value="<%= form.serie_03 %>" maxlength="4" minlength="4" pattern="[A-Za-z0-9]{4}" placeholder="B001" />
    </div>
    <div class="field">
      <label for="correlativo_inicio_03">Correlativo inicial</label>
      <input type="number" id="correlativo_inicio_03" name="correlativo_inicio_03" value="<%= form.correlativo_inicio_03 %>" min="1" step="1" />
    </div>
    <div class="field">
      <label for="correlativo_digitos_03">Dígitos correlativo</label>
      <input type="number" id="correlativo_digitos_03" name="correlativo_digitos_03" value="<%= form.correlativo_digitos_03 %>" min="1" max="20" step="1" placeholder="8" />
    </div>

    <div class="field field-full"><strong>Nota crédito (07)</strong></div>
    <div class="field">
      <label for="serie_07">Serie</label>
      <input type="text" id="serie_07" name="serie_07" value="<%= form.serie_07 %>" maxlength="4" minlength="4" pattern="[A-Za-z0-9]{4}" placeholder="FC01" />
    </div>
    <div class="field">
      <label for="correlativo_inicio_07">Correlativo inicial</label>
      <input type="number" id="correlativo_inicio_07" name="correlativo_inicio_07" value="<%= form.correlativo_inicio_07 %>" min="1" step="1" />
    </div>
    <div class="field">
      <label for="correlativo_digitos_07">Dígitos correlativo</label>
      <input type="number" id="correlativo_digitos_07" name="correlativo_digitos_07" value="<%= form.correlativo_digitos_07 %>" min="1" max="20" step="1" placeholder="8" />
    </div>

    <div class="field field-full"><strong>Nota débito (08)</strong></div>
    <div class="field">
      <label for="serie_08">Serie</label>
      <input type="text" id="serie_08" name="serie_08" value="<%= form.serie_08 %>" maxlength="4" minlength="4" pattern="[A-Za-z0-9]{4}" placeholder="FD01" />
    </div>
    <div class="field">
      <label for="correlativo_inicio_08">Correlativo inicial</label>
      <input type="number" id="correlativo_inicio_08" name="correlativo_inicio_08" value="<%= form.correlativo_inicio_08 %>" min="1" step="1" />
    </div>
    <div class="field">
      <label for="correlativo_digitos_08">Dígitos correlativo</label>
      <input type="number" id="correlativo_digitos_08" name="correlativo_digitos_08" value="<%= form.correlativo_digitos_08 %>" min="1" max="20" step="1" placeholder="8" />
    </div>

    <div class="field field-full"><strong>Guía remisión (09)</strong></div>
    <div class="field">
      <label for="serie_09">Serie</label>
      <input type="text" id="serie_09" name="serie_09" value="<%= form.serie_09 %>" maxlength="4" minlength="4" pattern="[A-Za-z0-9]{4}" placeholder="T001" />
    </div>
    <div class="field">
      <label for="correlativo_inicio_09">Correlativo inicial</label>
      <input type="number" id="correlativo_inicio_09" name="correlativo_inicio_09" value="<%= form.correlativo_inicio_09 %>" min="1" step="1" />
    </div>
    <div class="field">
      <label for="correlativo_digitos_09">Dígitos correlativo</label>
      <input type="number" id="correlativo_digitos_09" name="correlativo_digitos_09" value="<%= form.correlativo_digitos_09 %>" min="1" max="20" step="1" placeholder="8" />
    </div>
  </div>
</fieldset>

<fieldset class="fieldset">
  <legend>SUNAT / SOL</legend>
  <div class="form-grid">
    <div class="field">
      <label for="solUser">Usuario SOL</label>
      <input type="text" id="solUser" name="solUser" value="<%= form.solUser %>" autocomplete="off" placeholder="MODDATOS" />
    </div>
    <div class="field">
      <label for="solPass">Clave SOL</label>
      <input
        type="password"
        id="solPass"
        name="solPass"
        value=""
        autocomplete="new-password"
        placeholder="<%= form.tieneSolPass ? 'Configurada — dejar vacío para no cambiar' : 'Clave SOL' %>"
      />
    </div>
  </div>
</fieldset>

<fieldset class="fieldset">
  <legend>Certificado digital (.pfx / .p12)</legend>
  <div class="form-grid">
    <div class="field">
      <label for="certificatePassword">Contraseña del certificado</label>
      <input
        type="password"
        id="certificatePassword"
        name="certificatePassword"
        value=""
        autocomplete="new-password"
        placeholder="<%= form.tieneCertificatePassword ? 'Configurada — dejar vacío para no cambiar' : 'Contraseña del .pfx' %>"
      />
    </div>
    <div class="field">
      <label for="certificado">Archivo certificado</label>
      <input type="file" id="certificado" name="certificado" accept=".pfx,.p12,.pem" />
      <p class="field-hint">Se guarda en R2: certificados/<%= form.ruc || '{RUC}' %>/</p>
    </div>
    <% if (form.rutaFirma) { %>
      <div class="field field-full">
        <label>Certificado en almacenamiento</label>
        <p class="field-hint"><code><%= form.rutaFirma %></code></p>
      </div>
    <% } %>
    <div class="field field-check">
      <label>
        <input type="checkbox" name="tieneCertificado" <%= form.tieneCertificado ? 'checked' : '' %> />
        Certificado configurado
      </label>
    </div>
  </div>
</fieldset>

<fieldset class="fieldset">
  <legend>Dirección fiscal (opcional)</legend>
  <div class="form-grid">
    <div class="field">
      <label for="ubigeo">Ubigeo (6 dígitos INEI)</label>
      <input type="text" id="ubigeo" name="ubigeo" value="<%= form.ubigeo %>" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" placeholder="150101" />
      <p class="field-hint">Ej. 150101 (Lima). Debe ser numérico; SUNAT rechaza valores como "123df".</p>
    </div>
    <div class="field">
      <label for="departamento">Departamento</label>
      <input type="text" id="departamento" name="departamento" value="<%= form.departamento %>" />
    </div>
    <div class="field">
      <label for="provincia">Provincia</label>
      <input type="text" id="provincia" name="provincia" value="<%= form.provincia %>" />
    </div>
    <div class="field">
      <label for="distrito">Distrito</label>
      <input type="text" id="distrito" name="distrito" value="<%= form.distrito %>" />
    </div>
    <div class="field field-full">
      <label for="direccion">Dirección</label>
      <input type="text" id="direccion" name="direccion" value="<%= form.direccion %>" />
    </div>
    <div class="field">
      <label for="codLocal">Cód. local</label>
      <input type="text" id="codLocal" name="codLocal" value="<%= form.codLocal %>" maxlength="4" />
    </div>
  </div>
</fieldset>
