<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — BackEnd Easy</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="header">
    <h1>BackEnd Easy</h1>
    <p>Panel web</p>
  </header>

  <main class="container layout-with-nav">
    <%- include('../partials/nav', { active: 'comprobantes' }) %>

    <div class="main-content">
      <section class="card">
        <div class="card-header-row">
          <div>
            <h2><%= title %></h2>
            <p class="api-hint"><%= total %> comprobante(s)</p>
          </div>
        </div>

        <%- include('../partials/flash', { flash }) %>

        <% if (comprobantes.length === 0) { %>
          <p class="empty-state">No hay comprobantes registrados.</p>
        <% } else { %>
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Tipo</th>
                  <th>Número</th>
                  <th>Cliente</th>
                  <th>RUC empresa</th>
                  <th>Fecha</th>
                  <th>Total</th>
                  <th>Estado</th>
                </tr>
              </thead>
              <tbody>
                <% comprobantes.forEach(function(c) { %>
                  <tr>
                    <td><%= c.tipoDocLabel %></td>
                    <td><code><%= c.numero %></code></td>
                    <td>
                      <strong><%= c.clienteNombre %></strong>
                      <% if (c.clienteDoc) { %>
                        <br><span class="muted"><%= c.clienteDoc %></span>
                      <% } %>
                    </td>
                    <td class="muted"><%= c.companyRuc %></td>
                    <td class="muted"><%= c.fechaEmision || '—' %></td>
                    <td><%= c.tipoMoneda %> <%= c.total %></td>
                    <td>
                      <span class="badge badge-estado-<%= (c.estado || '').toLowerCase() %>"><%= c.estado %></span>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </div>
  </main>
</body>
</html>
