<div class="field">
  <label for="email">Email</label>
  <input
    type="email"
    id="email"
    name="email"
    value="<%= form.email || '' %>"
    placeholder="usuario@empresa.com"
    required
  />
</div>

<% if (!isEdit) { %>
  <div class="field">
    <label for="contrasena">Contraseña</label>
    <input
      type="password"
      id="contrasena"
      name="contrasena"
      placeholder="Mínimo 6 caracteres"
      minlength="6"
      required
    />
  </div>
<% } else { %>
  <div class="field">
    <label for="nuevaContrasena">Nueva contraseña (opcional)</label>
    <input
      type="password"
      id="nuevaContrasena"
      name="nuevaContrasena"
      placeholder="Dejar vacío para no cambiar"
      autocomplete="new-password"
      value=""
    />
    <span class="field-hint">Solo completa este campo si quieres cambiar la contraseña.</span>
  </div>
<% } %>

<div class="field">
  <label for="rol">Rol</label>
  <select id="rol" name="rol" required>
    <% roles.forEach(function(r) { %>
      <option value="<%= r %>" <%= form.rol === r ? 'selected' : '' %>><%= r %></option>
    <% }); %>
  </select>
  <span class="field-hint" id="rol-hint">
    Administrador: acceso total (puede ver otros almacenes). Usuario: solo su almacén en la app.
  </span>
</div>

<div class="field">
  <label for="estado">Estado</label>
  <select id="estado" name="estado" required>
    <% estados.forEach(function(e) { %>
      <option value="<%= e %>" <%= form.estado === e ? 'selected' : '' %>><%= e %></option>
    <% }); %>
  </select>
</div>

<div class="field">
  <label for="companyId">Empresa</label>
  <select id="companyId" name="companyId" required>
    <option value="">— Sin empresa —</option>
    <% companies.forEach(function(c) { %>
      <option
        value="<%= String(c.id) %>"
        data-ruc="<%= c.ruc %>"
        <%= String(form.companyId) === String(c.id) ? 'selected' : '' %>
      >
        <%= c.nombre %> (RUC <%= c.ruc %>)
      </option>
    <% }); %>
  </select>
  <span class="field-hint" id="company-hint">Obligatoria. Define la empresa del usuario.</span>
</div>

<div class="field" id="almacen-field">
  <label for="almacenId">Almacén</label>
  <select id="almacenId" name="almacenId" required>
    <option value="">— Seleccionar almacén —</option>
  </select>
  <span class="field-hint">Obligatorio para Admin y Usuario. Almacén principal de trabajo en la app móvil.</span>
</div>

<script>
(function () {
  var company = document.getElementById('companyId');
  var almacenField = document.getElementById('almacen-field');
  var almacen = document.getElementById('almacenId');
  var allAlmacenes = <%- JSON.stringify(almacenes.map(function(a) {
    return {
      id: a.id,
      nombre: a.nombre,
      codigo: a.codigo || '',
      companyRuc: a.companyRuc,
      activo: a.activo !== false,
    };
  })) %>;
  var selectedAlmacenId = <%- JSON.stringify(form.almacenId || '') %>;

  function selectedCompanyRuc() {
    var opt = company.options[company.selectedIndex];
    return opt ? opt.getAttribute('data-ruc') || '' : '';
  }

  function almacenLabel(item) {
    var label = item.nombre;
    if (item.codigo) label += ' (' + item.codigo + ')';
    if (!item.activo) label += ' — inactivo';
    return label;
  }

  function rebuildAlmacenOptions() {
    var ruc = selectedCompanyRuc();
    var hasCompany = Boolean(ruc);
    almacenField.style.display = hasCompany ? '' : 'none';
    almacen.required = hasCompany;

    var previous = almacen.value || selectedAlmacenId || '';
    almacen.innerHTML = '<option value="">— Seleccionar almacén —</option>';

    if (!hasCompany) {
      almacen.value = '';
      return;
    }

    allAlmacenes
      .filter(function (item) { return item.companyRuc === ruc; })
      .forEach(function (item) {
        var opt = document.createElement('option');
        opt.value = item.id;
        opt.textContent = almacenLabel(item);
        almacen.appendChild(opt);
      });

    if (previous && almacen.querySelector('option[value="' + previous + '"]')) {
      almacen.value = previous;
    }
  }

  company.addEventListener('change', function () {
    selectedAlmacenId = '';
    rebuildAlmacenOptions();
  });
  rebuildAlmacenOptions();
})();
</script>
