PORT=3000
NODE_ENV=development

# MySQL — Prisma arma DATABASE_URL automáticamente desde estas variables
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_system  
DB_USER=root
DB_PASSWORD=77437644

# Solo si prefieres URL completa (tiene prioridad sobre DB_*)
# DATABASE_URL=mysql://root:tu_password_mysql@localhost:3306/db_api_system

# Si falla con "auth_gssapi_client", en MySQL/MariaDB ejecuta:
# ALTER USER 'root'@'localhost' IDENTIFIED VIA mysql_native_password USING PASSWORD('tu_clave');
# FLUSH PRIVILEGES;

# JWT (autenticación)
JWT_SECRET=tu_clave_secreta_larga
JWT_REFRESH_SECRET=otra_clave_secreta_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Servicio PHP EMISOR (emisión SUNAT)
EMISOR_API_URL=http://localhost:8080
EMISOR_API_TIMEOUT_MS=120000
# true = permite emitir sin credenciales SUNAT en la empresa (EMISOR usa demo del .env)
EMISOR_SUNAT_ALLOW_INCOMPLETE=false

# Cloudflare R2 (bucket: sistemafacturacion)
S3_ENDPOINT=https://ee120001475f11c2557f8e8363584b10.r2.cloudflarestorage.com
S3_BUCKET=sistemafacturacion
S3_REGION=auto
S3_ACCESS_KEY_ID=tu_access_key_r2
S3_SECRET_ACCESS_KEY=tu_secret_key_r2
# Carpetas dentro del bucket
S3_PREFIX_COMPROBANTES=comprobantes
S3_PREFIX_CERTIFICADOS=certificados
# URL pública del bucket (R2 public bucket o dominio custom) — obligatoria en producción con R2
# Ejemplo: https://pub-xxxx.r2.dev  o  https://archivos.tudominio.com
S3_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
