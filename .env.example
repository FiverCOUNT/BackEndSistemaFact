PORT=3000
NODE_ENV=development

# MySQL — Prisma arma DATABASE_URL automáticamente desde estas variables
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_api_system
DB_USER=root
DB_PASSWORD=tu_password_mysql

# Solo si prefieres URL completa (tiene prioridad sobre DB_*)
# DATABASE_URL=mysql://root:tu_password_mysql@localhost:3306/db_api_system

# Si falla con "auth_gssapi_client", en MySQL/MariaDB ejecuta:
# ALTER USER 'root'@'localhost' IDENTIFIED VIA mysql_native_password USING PASSWORD('tu_clave');
# FLUSH PRIVILEGES;

# JWT (autenticación)
JWT_SECRET=tu_clave_secreta_larga
JWT_REFRESH_SECRET=otra_clave_secreta_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
