{
  "name": "backend-easy",
  "version": "1.0.0",
  "description": "Backend MVC con API REST y vista principal",
  "main": "src/server.js",
  "scripts": {
    "postinstall": "prisma generate",
    "db:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-db.ps1",
    "db:push": "node scripts/with-env.js db push",
    "db:migrate": "node scripts/with-env.js migrate dev",
    "db:migrate:deploy": "node scripts/with-env.js migrate deploy",
    "db:verify": "node scripts/verify-mysql.js",
    "db:studio": "node scripts/with-env.js studio",
    "db:seed": "node prisma/seed.js",
    "start": "node src/server.js",
    "dev": "node scripts/dev-server.js",
    "dev:server": "node scripts/dev-server.js",
    "db:generate": "node scripts/with-env.js generate"
  },
  "keywords": [
    "mvc",
    "rest",
    "api",
    "nodejs"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pdfkit": "^0.19.1"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
